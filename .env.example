# Number of days before the end of the month to run the timesheet fill
DAYS_BEFORE_MONTH_END=4

# Set to "true" to bypass the date check for local development
BYPASS_DATE_CHECK=false

# Set to "false" to run Chrome in non-headless mode (useful for local debugging)
HEADLESS=true

# Sage API configuration — find your base URL in the browser when logged into Sage HR
SAGE_BASE_URL=https://yourcompany.sage.hr
SAGE_EMAIL=your@email.com
SAGE_PASSWORD=your_password

# Telegram notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id